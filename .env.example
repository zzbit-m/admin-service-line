# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/admin_portal

# Auth (required — app fails to start if SECRET_KEY is empty or "changeme")
SECRET_KEY=generate-a-long-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=admin-portal

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# LINE Login (required from PR2)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# LINE Messaging (LINE_MESSAGING_CHANNEL_SECRET required from PR2)
LINE_MESSAGING_CHANNEL_ID=
LINE_MESSAGING_CHANNEL_SECRET=
LINE_MESSAGING_ACCESS_TOKEN=
LINE_LIFF_ID=
LINE_ADMIN_RICH_MENU_ID=

# n8n webhook (required from PR4)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/your-webhook-uuid
